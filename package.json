{
  "name": "revbuddy",
  "version": "0.1.0",
  "description": "AI-powered code review companion with TUI interface",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "revbuddy": "dist/cli.js",
    "revbuddy-server": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "tui": "tsx src/cli.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.3.3",
    "@fastify/websocket": "^11.0.2",
    "ink": "^5.2.0",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-select-input": "^6.0.0",
    "react": "^18.3.1",
    "ws": "^8.18.0",
    "marked": "^15.0.7",
    "marked-terminal": "^7.3.0",
    "chalk": "^5.4.1",
    "zod": "^3.24.3",
    "nanoid": "^5.1.5",
    "eventemitter3": "^5.0.1",
    "cli-boxes": "^4.0.1"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.20",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.4",
    "vitest": "^3.1.3",
    "ink-testing-library": "^4.0.0"
  }
}
